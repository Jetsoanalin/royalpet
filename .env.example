# Root env for Vercel + local dev (mirrors server settings)

JWT_SECRET=
JWT_EXPIRES_IN=1d
DATABASE_PROVIDER=appwrite

# Appwrite — server
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69cb82450038c7fe298c
APPWRITE_PROJECT_NAME=Web5 Nexus
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=royalpetshop
APPWRITE_BUCKET_ID=royalpet-images

# Appwrite — client (Vite)
VITE_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69cb82450038c7fe298c
VITE_APPWRITE_PROJECT_NAME=Web5 Nexus
VITE_APPWRITE_DATABASE_ID=royalpetshop

STORAGE_PROVIDER=appwrite
STORAGE_PUBLIC_BASE_URL=
ALLOW_BULK_SYNC=true
CORS_ORIGINS=

CRON_SECRET=
NODE_ENV=production

VITE_API_URL=/api
