# Server configuration
PORT=4000

# JWT secret (use a strong random value in production)
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# Database provider: sql (SQLite/Postgres via Knex) or appwrite
DATABASE_PROVIDER=appwrite

# Appwrite (required when DATABASE_PROVIDER=appwrite)
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69cb82450038c7fe298c
APPWRITE_PROJECT_NAME=Web5 Nexus
APPWRITE_API_KEY=standard_d218d91fa0ee17a6284511a608ed0da655bc5ac88d47d9f6fd2d1f0577c540f89a6f23c1f8c292718a695e604c34eebf32b58b68eb44cf40b4dbbdbb70604f1b90de5764d7d43ad51460189ef89903f3f92efcc85a09f9035232b2a75725e27ed6c24fd70c444511ec02c7acc7376103abad934fc07b7fafa95fa9378df6175c
APPWRITE_DATABASE_ID=royalpetshop
APPWRITE_BUCKET_ID=royalpet-images

# CORS (comma-separated origins). Example: https://your-app.vercel.app
CORS_ORIGINS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info

# Uploads / storage
STORAGE_PROVIDER=appwrite
STORAGE_PUBLIC_BASE_URL=

# Bulk sync from staff UI
ALLOW_BULK_SYNC=true

# Vercel cron auth (Vercel sends Authorization: Bearer <CRON_SECRET> on cron hits)
CRON_SECRET=

# ── SQL fallback (local dev / tests) ───────────────────────────────────────
# DATABASE_PROVIDER=sql
# SQLITE_FILE=./data/royalpet.db
# DATABASE_URL=postgresql://...

# ── S3-compatible storage (optional alternative) ───────────────────────────
# STORAGE_PROVIDER=s3
# S3_BUCKET=royalpet-images
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
